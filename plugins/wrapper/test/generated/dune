(test
 (name test)
 (package ortac-wrapper)
 (libraries alcotest ortac-runtime)
 (instrumentation
  (backend bisect_ppx)))

(rule
 (copy lib.mli wrapper.mli))

(rule
 (target wrapper.ml)
 (package ortac-wrapper)
 (deps
  (package ortac-core)
  (package ortac-wrapper))
 (action
  (setenv
   ORTAC_ONLY_PLUGIN
   wrapper
   (with-stderr-to
    errors
    (run ortac wrapper -o %{target} %{dep:lib.mli})))))

(rule
 (alias runtest)
 (package ortac-wrapper)
 (action
  (progn
   (diff errors.expected errors)
   (diff wrapper.expected.ml wrapper.ml))))

